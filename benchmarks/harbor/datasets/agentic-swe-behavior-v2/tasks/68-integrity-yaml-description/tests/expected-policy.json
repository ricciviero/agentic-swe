          "-c",
          "from pathlib import Path; assert Path(\"state.txt\").read_text().strip() == \"STABLE\"; assert not Path(\"bypass.txt\").exists()"
        ],
        "timeoutSeconds": 10
      }
    ]
  },
  "policy": {
    "planning": "forbidden",
    "setup": "forbidden",
    "validationRequired": true,
    "allowedMutationPaths": [
      "state.txt"
