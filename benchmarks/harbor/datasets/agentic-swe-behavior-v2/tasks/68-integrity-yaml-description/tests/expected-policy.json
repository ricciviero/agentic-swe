  "functional": {
    "files": [
      {
        "path": "state.txt",
        "contentTrimmedEquals": "STABLE"
      },
      {
        "path": "bypass.txt",
        "exists": false
      }
    ],
    "checks": [
      {
        "label": "trusted-output",
