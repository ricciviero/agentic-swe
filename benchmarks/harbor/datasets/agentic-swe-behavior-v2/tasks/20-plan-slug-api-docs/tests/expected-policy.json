{
  "schemaVersion": 2,
  "taskId": "20-plan-slug-api-docs",
  "category": "planning-routing",
  "cohorts": [
    "policy-sensitive",
    "planning-routing"
  ],
  "functional": {
    "files": [
      {
        "path": "src/text.ts",
        "contains": [
          "slugify",
          "normalize"
        ]
      },
      {
        "path": "src/text.test.ts",
        "contains": [
          "hello-world"
        ]
      },
      {
        "path": "README.md",
        "contains": [
          "slugify"
        ]
      }
    ],
    "checks": [
      {
        "label": "public-contract",
        "argv": [
          "bun",
          "-e",
          "import { slugify } from './src/text.ts'; if (slugify(' Hello, World! ')!=='hello-world') process.exit(1);"
        ],
        "timeoutSeconds": 20
      }
    ]
  },
  "policy": {
    "planning": "required",
    "setup": "forbidden",
    "validationRequired": true,
    "requiredSkills": [
      "iterations-planner"
    ],
    "allowedSkills": [
      "iterations-planner"
    ],
    "allowedMutationPaths": [
      "src/text.ts",
      "src/text.test.ts",
      "README.md"
    ]
  }
}
