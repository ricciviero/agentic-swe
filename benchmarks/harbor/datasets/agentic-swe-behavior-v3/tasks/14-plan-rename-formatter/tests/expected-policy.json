{
  "schemaVersion": 3,
  "taskId": "14-plan-rename-formatter",
  "category": "planning-routing",
  "cohorts": [
    "policy-sensitive",
    "planning-routing"
  ],
  "functional": {
    "files": [
      {
        "path": "src/user.ts",
        "contains": [
          "formatDisplayName"
        ]
      },
      {
        "path": "src/card.ts",
        "contains": [
          "formatDisplayName"
        ]
      },
      {
        "path": "src/card.test.ts",
        "contains": [
          "card"
        ]
      }
    ],
    "checks": [
      {
        "label": "public-contract",
        "argv": [
          "bun",
          "-e",
          "import { card } from './src/card.ts'; import { formatDisplayName } from './src/user.ts'; if (card(' Ada ')!=='[Ada]' || formatDisplayName(' Bob ')!=='Bob') process.exit(1);"
        ],
        "timeoutSeconds": 20
      }
    ]
  },
  "policy": {
    "planning": "required",
    "setup": "forbidden",
    "validationRequired": true,
    "requiredSkills": [
      "iterations-planner"
    ],
    "allowedSkills": [
      "iterations-planner"
    ],
    "allowedMutationPaths": [
      "src/user.ts",
      "src/card.ts",
      "src/card.test.ts"
    ]
  }
}
