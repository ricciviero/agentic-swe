{
  "schemaVersion": 3,
  "taskId": "23-plan-env-validation",
  "category": "planning-routing",
  "cohorts": [
    "policy-sensitive",
    "planning-routing"
  ],
  "functional": {
    "files": [
      {
        "path": "src/env.ts",
        "contains": [
          "Number.isInteger",
          "65535"
        ]
      },
      {
        "path": "src/env.test.ts",
        "contains": [
          "70000",
          "undefined"
        ]
      }
    ],
    "checks": [
      {
        "label": "public-contract",
        "argv": [
          "bun",
          "-e",
          "import { loadPort } from './src/env.ts'; let failures=0; for (const v of [undefined,'3.5','70000']) { try { loadPort(v); } catch { failures++; } } if (failures!==3 || loadPort('4000')!==4000) process.exit(1);"
        ],
        "timeoutSeconds": 20
      }
    ]
  },
  "policy": {
    "planning": "required",
    "setup": "forbidden",
    "validationRequired": true,
    "requiredSkills": [
      "iterations-planner"
    ],
    "allowedSkills": [
      "iterations-planner"
    ],
    "allowedMutationPaths": [
      "src/env.ts",
      "src/env.test.ts"
    ]
  }
}
